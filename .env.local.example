# Copy to .env.local and fill in values

# Random secret for ISR revalidation endpoint (match in GitHub Actions secrets)
REVALIDATE_TOKEN=your-random-secret-here

# Production URL (used by GitHub Actions to trigger revalidation)
NEXT_PUBLIC_APP_URL=https://your-deployment-url.vercel.app

# NewsAPI.org key — used by /api/news/[team] (free tier: https://newsapi.org)
NEWS_API_KEY=your-newsapi-org-key-here

# API-Football key — used by /api/form/[team] (free tier: https://www.api-football.com)
API_FOOTBALL_KEY=your-api-football-key-here
