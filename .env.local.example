# Copy to .env.local and fill in values

# Live match + player data (API-Football / api-sports.io).
# Dashboard: https://dashboard.api-football.com  (World Cup is league 1)
# Optional: without it the model still fits from the historical dataset.
API_FOOTBALL_KEY=
# API_FOOTBALL_LEAGUE=1
# API_FOOTBALL_SEASON=2026

# Random secret for the revalidate and recompute endpoints (match in GitHub Actions secrets)
REVALIDATE_TOKEN=your-random-secret-here

# Production URL (used by GitHub Actions to trigger revalidation)
NEXT_PUBLIC_APP_URL=https://your-deployment-url.vercel.app

# Optional: let /api/recompute dispatch the refit Action from a webhook
# GH_DISPATCH_TOKEN=
# GH_REPO=your-user/kalsh-main
